{
  "version": "v1.0",
  "schema_status": "research_ready_draft",
  "event_types": [
    "Threat",
    "Resource",
    "Uncertainty",
    "Navigation",
    "Internal"
  ],
  "dimensions_order": [
    "impulsiveness",
    "caution",
    "greed",
    "optimism",
    "suspicion",
    "persistence",
    "randomness",
    "stability_seeking",
    "ambition",
    "patience",
    "curiosity",
    "fearfulness"
  ],
  "utility_weight_policy": {
    "raw_range": [
      -1.0,
      1.0
    ],
    "normalization": "l1",
    "eps": 1e-09,
    "loader_rule": "weights = weights / max(sum(abs(weights)), eps)",
    "fallback": "if all-zero or non-finite, replace with zeros"
  },
  "risk_policy": {
    "formula": "final_risk = clamp(0, 1, base_risk + risk_bias + sum(risk_trait_weights_i * trait_i))",
    "fallback": "if non-finite, use base_risk",
    "clamp_range": [
      0.0,
      1.0
    ],
    "default_failure_threshold": 0.72
  },
  "success_policy": {
    "default_model": "linear_risk_complement",
    "default_model_kwargs": {},
    "registry_models": [
      "linear_risk_complement",
      "logistic",
      "linear_clip",
      "threshold"
    ],
    "default_probability_formula": "success_prob = clamp(0, 1, 1 - final_risk)",
    "alternative_formula": "success_prob = logistic(success_bias - success_steepness * final_risk)",
    "fallback": "if non-finite, use clamp(0, 1, 1 - base_risk)",
    "clamp_range": [
      0.0,
      1.0
    ],
    "default_success_bias": 1.0,
    "default_success_steepness": 6.0
  },
  "state_policy": {
    "state_variables": [
      "stress",
      "noise",
      "risk_drift",
      "health",
      "intel"
    ],
    "decay_rates": {
      "stress": 0.88,
      "noise": 0.9,
      "risk_drift": 0.87,
      "risk": 0.93,
      "health_regen": 0.02
    },
    "default_state_effects": {
      "on_success": {
        "stress_delta": 0.0,
        "noise_delta": 0.0,
        "risk_drift_delta": 0.0,
        "health_delta": 0.0,
        "intel_delta": 0.0
      },
      "on_failure": {
        "stress_delta": 0.0,
        "noise_delta": 0.0,
        "risk_drift_delta": 0.0,
        "health_delta": 0.0,
        "intel_delta": 0.0
      }
    }
  },
  "reward_policy": {
    "success_field": "reward_effects",
    "failure_field": "failure_outcomes",
    "state_field": "state_effects",
    "required_reward_keys": [
      "utility_delta",
      "risk_delta",
      "popularity_shift",
      "trait_deltas"
    ]
  },
